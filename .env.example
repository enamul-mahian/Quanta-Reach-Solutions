# =========================================================================
# MetaFore Technologies - Environment Variables Blueprint
# =========================================================================
# আপনার আসল কি (Keys) গুলো ব্যবহার করতে এই ফাইলটি কপি করে `.env` নামে 
# একটি নতুন ফাইল তৈরি করুন এবং সেখানে আসল মানগুলো বসান।
# সিকিউরিটির জন্য `.env` ফাইলটি কখনোই গিটহাবে বা পাবলিকলি শেয়ার করবেন না।
# =========================================================================

# 1. Firebase Configuration (Firestore & Auth)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# 2. Cloudinary Configuration (Strict Media Rule)
# সিকিউরিটির জন্য ফ্রন্টএন্ড কোডে কখনোই API Secret ব্যবহার করবেন না। 
# ছবি এবং ভিডিও আপলোডের জন্য ক্লাউডিনারির Restricted Unsigned Upload Preset ব্যবহার করুন।
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_unsigned_upload_preset_here
VITE_CLOUDINARY_FOLDER=metafore_agency